#!/bin/sh
# Shared pre-commit hook: block the commit if the test suite fails.
# Enabled via: git config core.hooksPath .githooks
# Works no matter which tool (Claude Code, Cursor, VS Code, a human) made the change.

echo "pre-commit: running snipvault test suite..."
python -m unittest discover -s tests
status=$?
if [ $status -ne 0 ]; then
    echo ""
    echo "pre-commit: tests FAILED - commit blocked."
    echo "Fix the failures (or run 'git commit --no-verify' to bypass in an emergency)."
    exit 1
fi
echo "pre-commit: all tests passed."
exit 0
